datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

enum Role {
  SAVER
  BORROWER
  ADMIN
}

enum KycStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  FAILED
}

enum KybStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  FAILED
}

enum LoanStatus {
  PENDING
  AI_ASSESSED
  APPROVED
  DISBURSED
  ACTIVE
  REPAID
  DEFAULTED
  REJECTED
}

enum AccountStatus {
  ACTIVE
  INACTIVE
}

enum WebhookStatus {
  PENDING
  PROCESSED
  FAILED
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  name           String
  phoneNumber    String?
  role           Role            @default(SAVER)
  kycStatus      KycStatus       @default(UNVERIFIED)
  bvn            String?
  nin            String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  virtualAccount VirtualAccount?
  borrowerProfile Borrower?
  wallets        Wallet[]
  ledger         Ledger[]
}

model Borrower {
  id              String            @id @default(uuid())
  userId          String            @unique
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName     String
  cacRcNumber     String            @unique
  businessTin     String            @unique
  sector          String
  kybStatus       KybStatus         @default(UNVERIFIED)
  creditScore     Int?
  creditGrade     String?
  approvedLimit   Decimal?
  splitIntensity  Int               @default(10)
  terminals       String[]          @default([])
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  loanApplications LoanApplication[]
  repaymentAccount VirtualAccount?
  documents       KycDocument[]
}

model LoanApplication {
  id              String     @id @default(uuid())
  borrowerId      String
  borrower        Borrower   @relation(fields: [borrowerId], references: [id], onDelete: Cascade)
  amountRequested Decimal
  amountApproved  Decimal?
  interestRate    Decimal?
  termDays        Int
  status          LoanStatus @default(PENDING)
  creditScore     Int?
  creditGrade     String?
  aiAnalysis      Json?
  contractBondId  String?
  amountRepaid    Decimal    @default(0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model VirtualAccount {
  id            String        @id @default(uuid())
  userId        String?       @unique
  user          User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  borrowerId    String?       @unique
  borrower      Borrower?     @relation(fields: [borrowerId], references: [id], onDelete: Cascade)
  accountNumber String        @unique
  bankName      String
  accountName   String
  reference     String        @unique
  status        AccountStatus @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model WebhookLog {
  id        String        @id @default(uuid())
  provider  String
  eventType String
  payload   Json
  status    WebhookStatus @default(PENDING)
  error     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Wallet {
  id              String   @id @default(uuid())
  userId          String
  address         String   @unique
  derivationIndex Int      @unique
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Ledger {
  id        String   @id @default(uuid())
  userId    String
  amount    String
  type      String   // 'DEPOSIT', 'WITHDRAWAL', 'YIELD'
  status    String   // 'PENDING', 'COMPLETED', 'FAILED'
  txHash    String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id        String   @id @default(uuid())
  txHash    String?  @unique
  type      String   // 'DEPOSIT', 'WITHDRAWAL', 'BOND', 'SWEEP'
  status    String   // 'PENDING', 'MINED', 'FAILED'
  toAddress String
  amount    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model KycDocument {
  id          String   @id @default(uuid())
  borrowerId  String
  borrower    Borrower @relation(fields: [borrowerId], references: [id], onDelete: Cascade)
  type        String   // 'CAC_CERTIFICATE' | 'DIRECTOR_ID'
  fileName    String
  fileSize    Int
  base64Data  String
  uploadedAt  DateTime @default(now())
}
