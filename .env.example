# Server Configuration
PORT=5000
NODE_ENV=development

# Database Connection (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/izumi"

# AI Model Credentials (Gemini API)
GEMINI_API_KEY="your-gemini-api-key-here"

# Nomba Rails API Credentials
NOMBA_API_KEY="your-nomba-api-key"
NOMBA_CLIENT_ID="your-nomba-client-id"
NOMBA_CLIENT_SECRET="your-nomba-client-secret"
NOMBA_ACCOUNT_ID="your-nomba-account-id"
NOMBA_BASE_URL="https://api.nomba.com/v1" # Use Sandbox or Production URL
